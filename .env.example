NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=toyimbor
APP_TIMEZONE=Asia/Tashkent

SESSION_SECRET=replace-with-a-long-random-session-secret
SESSION_COOKIE_NAME=toyimbor_session
SESSION_TTL_DAYS=30
SESSION_SECURE=false

SEED_SAMPLE_DATA=true
SEED_ADMIN_EMAIL=admin@toyimbor.uz
SEED_ADMIN_PASSWORD=Admin123!
SEED_CUSTOMER_EMAIL=customer@toyimbor.uz
SEED_CUSTOMER_PASSWORD=Customer123!
SEED_VENDOR_EMAIL=vendor@toyimbor.uz
SEED_VENDOR_PASSWORD=Vendor123!

ALLOW_MEMORY_FALLBACK=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
