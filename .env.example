NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/toyimbor?retryWrites=true&w=majority
MONGODB_DB=toyimbor
APP_TIMEZONE=Asia/Tashkent

SESSION_SECRET=change-this-session-secret
SESSION_COOKIE_NAME=toyimbor_session
SESSION_TTL_DAYS=30
SESSION_SECURE=false

SEED_SAMPLE_DATA=true
SEED_CUSTOMER_EMAIL=customer@example.com
SEED_CUSTOMER_PASSWORD=Customer123!
SEED_VENDOR_EMAIL=vendor@example.com
SEED_VENDOR_PASSWORD=Vendor123!

ALLOW_MEMORY_FALLBACK=false

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
